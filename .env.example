# Daralla Bot - шаблон конфигурации
# Скопируйте в .env и заполните значения

# === Обязательные ===
#TELEGRAM_TOKEN=
#ADMIN_ID=
#YOOKASSA_SHOP_ID=
#YOOKASSA_SECRET_KEY=

# === Webhook ===
# URL с SSL для приёма webhook YooKassa (например https://daralla.ru/webhook/yookassa)
#WEBHOOK_URL=

# === Опционально ===
# URL веб-сайта для кнопки «Вернуться на сайт»
#WEBSITE_URL=

# Ngrok (для локальной разработки)
#NGROK_AUTH_TOKEN=



# === Remnawave (подписки) ===
# Если заданы — подписки управляются через Remnawave; локальная БД подписок не используется.
#REMNAWAVE_BASE_URL=
#REMNAWAVE_ADMIN_USERNAME=
#REMNAWAVE_ADMIN_PASSWORD=

# Модуль событий (реферальные конкурсы): 1 / true / yes чтобы включить
# EVENTS_MODULE_ENABLED=

# Ссылка на поддержку для экрана победителей (по умолчанию t.me/DarallaSupport)
# EVENTS_SUPPORT_URL=
