# Daralla Bot - шаблон конфигурации
# Скопируйте в .env и заполните значения

# === Обязательные ===
#TELEGRAM_TOKEN=
#ADMIN_ID=
#YOOKASSA_SHOP_ID=
#YOOKASSA_SECRET_KEY=

# === CryptoCloud (крипто-оплата) ===
# Токен API, Shop ID и секрет для проверки JWT в postback (из личного кабинета CryptoCloud)
# URL постбэка указать в настройках проекта: https://ваш-домен/webhook/cryptocloud
#CRYPTOCLOUD_API_TOKEN=
#CRYPTOCLOUD_SHOP_ID=
#CRYPTOCLOUD_WEBHOOK_SECRET=

# === Platega ===
# Merchant ID и секрет проекта (используются для create transaction и валидации webhook)
#PLATEGA_MERCHANT_ID=
#PLATEGA_SECRET=
# Базовый URL API (по умолчанию https://api.platega.io)
#PLATEGA_BASE_URL=https://api.platega.io
# Путь create transaction (по умолчанию /transaction/process)
#PLATEGA_CREATE_PATH=/transaction/process
# Способ оплаты (2 = СБП QR, 11 = карты, 13 = крипта)
#PLATEGA_PAYMENT_METHOD=2
# Валюта платежа
#PLATEGA_CURRENCY=RUB
# Return URL после успешной оплаты и URL при ошибке/отмене
#PLATEGA_RETURN_URL=https://daralla.ru/?payment_return=1
#PLATEGA_FAILED_URL=https://daralla.ru/?payment_return=0

# === Webhook (только для YooKassa) ===
# URL с SSL для приёма webhook YooKassa
#WEBHOOK_URL=https://daralla.ru/webhook/yookassa
# Порт веб-сервера (Quart/Hypercorn). По умолчанию 5000.
#WEBHOOK_PORT=5000

# === Mini App (кнопки «Открыть в приложении») ===
# URL мини-приложения для кнопок в меню, уведомлениях и рассылке. Задаётся отдельно от WEBHOOK_URL.
#WEBAPP_URL=https://daralla.ru/

# === Опционально ===
# URL веб-сайта для кнопки «Вернуться на сайт»
#WEBSITE_URL=https://daralla.ru

# Общий домен cookie для одного входа на daralla.ru и app.daralla.ru.
# Если не задан, cookie привязан к хосту, на котором пользователь вошёл (daralla.ru или app.daralla.ru — вход не шарится).
#AUTH_COOKIE_DOMAIN=.daralla.ru

# Ngrok (для локальной разработки)
#NGROK_AUTH_TOKEN=

# X-UI / py3xui: таймауты HTTP к панелям (сек.) и число повторов при сетевых сбоях (1–10, по умолчанию 5)
#XUI_HTTP_TIMEOUT_TOTAL=30
#XUI_HTTP_TIMEOUT_CONNECT=15
#XUI_HTTP_TIMEOUT_POOL=10
#XUI_PANEL_MAX_RETRIES=5

# === Брендинг ===
# Название VPN бренда (используется в подписках и интерфейсе)
#VPN_BRAND_NAME=Daralla VPN

# Имя бота в Telegram (для ссылок)
#BOT_USERNAME=Daralla_bot

# Ссылка на канал Telegram
#TELEGRAM_CHANNEL_URL=https://t.me/DarallaNews

# Ссылка на поддержку
#SUPPORT_URL=https://t.me/DarallaSupport

# === Цены ===
# Цена за 1 месяц подписки (в рублях)
#PRICE_MONTH=150

# Цена за 3 месяца подписки (в рублях)
#PRICE_3MONTH=350

# === Изображения ===
# Путь к изображению главного меню
#IMAGE_MAIN_MENU=images/main_menu.jpg

# Путь к изображению успешной оплаты
#IMAGE_PAYMENT_SUCCESS=images/payment_success.jpg

# Путь к изображению неудачной оплаты
#IMAGE_PAYMENT_FAILED=images/payment_failed.jpg

# Серверы X-UI добавляются через админ-панель (веб)

# Модуль событий (реферальные конкурсы): 1 / true / yes чтобы включить
#EVENTS_MODULE_ENABLED=1

# Ссылка на поддержку для экрана победителей
#EVENTS_SUPPORT_URL=https://t.me/DarallaSupport

# === Data retention policy ===
# Режим dry-run: 1/true — только логируем кандидатов на удаление, без фактического purge
#RETENTION_DRY_RUN=0

# Детальные платежи
#PAYMENTS_RETENTION_DAYS=365

# Подписки в статусе deleted
#DELETED_SUBSCRIPTIONS_RETENTION_DAYS=365

# Что делать со связями subscription_servers при удалении подписки:
# immediate (сразу) | deferred (позже в retention job)
#SUBSCRIPTION_SERVERS_ON_DELETE=immediate

# Авто-удаление неактивных пользователей (batch job)
#AUTO_DELETE_INACTIVE_USERS_DAYS=365

# Уведомления
#NOTIFICATIONS_SENT_RETENTION_DAYS=90
#NOTIFICATION_METRICS_RETENTION_DAYS=730

# Нагрузка серверов (raw)
#SERVER_LOAD_RETENTION_DAYS=30

# Event raw-детализация после завершения событий
#EVENTS_RAW_RETENTION_DAYS=365

# Ежедневные агрегаты аналитики
#DAILY_AGG_RETENTION_DAYS=730
