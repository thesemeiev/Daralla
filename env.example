# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_admin_telegram_id_here

# YooKassa Payment Configuration (если используется)
YOOKASSA_SHOP_ID=your_yookassa_shop_id
YOOKASSA_SECRET_KEY=your_yookassa_secret_key

# 3xui Server Configuration (если используется)
XUI_HOST=https://your-3xui-server.com
XUI_USERNAME=your_username
XUI_PASSWORD=your_password

# Database Configuration (опционально)
DATABASE_PATH=./data/vpn_keys.db
REFERRAL_DB_PATH=./data/referral_system.db
NOTIFICATIONS_DB_PATH=./data/notifications.db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./data/logs/bot.log

# Bot Settings
BOT_NAME=Daralla Bot
BOT_VERSION=1.0.0
